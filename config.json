{
  "browsers": [
    {
      "name": "Chrome",
      "history_path": "%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\History",
      "launch_command": "cmd /c start chrome \"{url}\""
    },
    {
      "name": "Edge",
      "history_path": "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data\\Default\\History",
      "launch_command": "cmd /c start msedge \"{url}\""
    }
  ],
  "ignore_processes": [
    "explorer.exe",
    "SearchHost.exe",
    "StartMenuExperienceHost.exe",
    "TextInputHost.exe",
    "ApplicationFrameHost.exe",
    "ShellExperienceHost.exe",
    "Widgets.exe",
    "SystemSettings.exe"
  ],
  "min_visit_count": 2,
  "history_lookback_hours": 18
}
